# Azure AI Foundry Configuration
FOUNDRY_PROJECT_ENDPOINT=https://your-project-endpoint.cognitiveservices.azure.com
FOUNDRY_MODEL=gpt-4o

# Azure AI Search Configuration (for Hybrid RAG)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key
AZURE_SEARCH_INDEX_NAME=your-search-index

# Kept for configuration parity with agentic-rag-app; Hybrid RAG uses AZURE_SEARCH_INDEX_NAME directly.
AZURE_SEARCH_KNOWLEDGE_BASE_NAME=your-knowledge-base

# Optional: semantic ranking configuration name in your Azure Search index
AZURE_SEARCH_SEMANTIC_CONFIGURATION=default

# Optional: set this only when your index has a vector field and you want vector + keyword hybrid retrieval
AZURE_SEARCH_VECTOR_FIELD_NAME=contentVector

# Optional: required only when AZURE_SEARCH_VECTOR_FIELD_NAME is set and embeddings are generated client-side
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_RESOURCE_URL=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
